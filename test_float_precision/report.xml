<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_a_model">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="o">
                        <t t-set="o" t-value="o.with_context(lang=o.env.lang)"/>   
                        <div class="page">
                            <h1>A Model</h1>
                            <div>Fixed Precision <span t-esc="o.fixed_precision"/></div>
                            <div>Zero Precision <span t-esc="o.zero_precision"/></div>
                            <div>No Precision <span t-esc="o.no_precision"/></div>
                            <div>---</div>
                            <div>Fixed Precision <span t-field="o.fixed_precision"/></div>
                            <div>Zero Precision <span t-field="o.zero_precision"/></div>
                            <div>No Precision <span t-field="o.no_precision"/></div>
                            <div>Price Unit
                                <span t-field="o.price_unit" t-options="{'widget': 'float'}"/>
                            </div>
                            <div> Price
                                <span
                                t-field="o.price"
                                t-options="{
                                    'widget': 'float',
                                    'precision': o.currency_id.decimal_places
                                }"
                                />
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="a_model_report_action" model="ir.actions.report">
            <field name="name">A Model Report Action</field>
            <field name="model">a.model</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">test_float_precision.report_a_model</field>
            <field name="report_file">test_float_precision.report_a_model</field>
            <field name="binding_model_id" ref="model_a_model"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
